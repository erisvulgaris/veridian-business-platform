// Veridian — Business Discovery Platform + Free ERP + Admin Panels
// Prisma schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  role         String   @default("customer") // super_admin | admin | moderator | owner | staff | customer
  businessId   String?  // for owner/staff — links to their business
  permissions  String   @default("[]") // JSON array of granular permissions
  avatar       String?
  active       Boolean  @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  adminActions AdminAction[]
  orders       Order[]      @relation("OrderUser")
  invoices     Invoice[]    @relation("InvoiceUser")
  customers    Customer[]
  expenses     Expense[]
  staffMembers Staff[]
}

model Business {
  id              String   @id @default(cuid())
  name            String
  slug            String   @unique
  tagline         String
  description     String
  logo            String
  coverImage      String
  gallery         String   // JSON array of image urls
  category        String
  subCategories   String   // JSON array
  verified        String   @default("basic") // basic | verified | premium | enterprise
  rating          Float    @default(0)
  reviewCount     Int      @default(0)
  lat             Float
  lng             Float
  address         String
  area            String
  city            String
  state           String
  pincode         String
  phone           String
  email           String
  website         String
  whatsapp        String?
  hours           String   // JSON { days: [{day, open, close}], openNow }
  isOpen          Boolean  @default(true)
  foundedYear     Int
  teamSize        String
  languages       String   // JSON array
  paymentMethods  String   // JSON array
  facilities      String   // JSON array
  deliveryOptions String   // JSON array
  social          String   // JSON object
  certifications  String   // JSON array
  awards          String   // JSON array
  viewCount       Int      @default(0)
  responseTime    String   @default("within an hour")
  trending        Boolean  @default(false)
  featured        Boolean  @default(false)
  recentlyVerified Boolean @default(false)
  promotion       String?  // JSON { title, description, expires }
  announcement    String?  // JSON { title, body, date }
  brandColor      String   @default("#0f766e")
  // Admin fields
  status          String   @default("active") // active | pending | suspended | rejected
  claimStatus     String   @default("unclaimed") // unclaimed | claimed | claim_pending
  ownerId         String?  // User who owns this business
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  products        Product[]
  services        Service[]
  reviews         Review[]
  enquiries       Enquiry[]
  messages        Message[]
  inventory       InventoryItem[]
  orders          Order[]
  invoices        Invoice[]
  customers       Customer[]
  expenses        Expense[]
  staff           Staff[]
  subscriptions   Subscription[]
}

model Product {
  id            String   @id @default(cuid())
  businessId    String
  business      Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  name          String
  slug          String
  description   String
  images        String   // JSON array
  category      String
  brand         String
  priceMin      Int
  priceMax      Int
  currency      String   @default("INR")
  cost          Int      @default(0) // cost price for ERP
  sku           String?
  variants      String   // JSON array
  specifications String  // JSON array [{label, value}]
  availability  String   @default("in_stock") // in_stock | low_stock | preorder | out_of_stock | made_to_order
  stockQty      Int      @default(0) // actual stock for ERP
  reorderLevel  Int      @default(5) // low stock alert threshold
  documents     String   // JSON array
  faqs          String   // JSON array
  featured      Boolean  @default(false)
  viewCount     Int      @default(0)
  createdAt     DateTime @default(now())

  inventory     InventoryItem[]
  orderItems    OrderItem[]

  @@index([businessId])
}

model Service {
  id           String   @id @default(cuid())
  businessId   String
  business     Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  name         String
  slug         String
  description  String
  pricing      String
  duration     String
  coverageArea String
  requirements String   // JSON array
  deliverables String   // JSON array
  photos       String   // JSON array
  faqs         String   // JSON array
  featured     Boolean  @default(false)
  createdAt    DateTime @default(now())

  @@index([businessId])
}

model Review {
  id            String   @id @default(cuid())
  businessId    String
  business      Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  authorName    String
  authorAvatar  String
  rating        Int
  title         String
  content       String
  photos        String   // JSON array
  verified      Boolean  @default(false)
  helpful       Int      @default(0)
  businessReply String?
  // Moderation
  status        String   @default("published") // published | pending | flagged | removed
  flaggedReason String?
  createdAt     DateTime @default(now())

  @@index([businessId])
}

model Enquiry {
  id          String   @id @default(cuid())
  businessId  String
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customerName String
  customerEmail String
  customerPhone String?
  company     String?
  subject     String
  message     String
  productId   String?
  serviceName String?
  quantity    String?
  budget      String?
  timeline    String?
  status      String   @default("new") // new | read | replied | closed
  createdAt   DateTime @default(now())

  @@index([businessId])
}

model Message {
  id          String   @id @default(cuid())
  businessId  String
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  threadId    String
  senderName  String
  senderEmail String
  senderRole  String   // customer | business
  content     String
  read        Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([businessId])
  @@index([threadId])
}

model Category {
  id    String @id @default(cuid())
  name  String
  slug  String @unique
  icon  String
  color String
  count Int    @default(0)
}

// === ERP Models ===

model InventoryItem {
  id          String   @id @default(cuid())
  businessId  String
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  productId   String
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  sku         String?
  stockQty    Int      @default(0)
  reorderLevel Int     @default(5)
  location    String?
  notes       String?
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())

  @@index([businessId])
  @@index([productId])
}

model Order {
  id            String   @id @default(cuid())
  businessId    String
  business      Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  userId        String?
  user          User?    @relation("OrderUser", fields: [userId], references: [id])
  orderNumber   String
  customerName  String
  customerEmail String?
  customerPhone String?
  shippingAddress String?
  items         String   // JSON array of { productId, name, qty, price, total }
  subtotal      Int
  tax           Int      @default(0)
  discount      Int      @default(0)
  total         Int
  status        String   @default("new") // new | confirmed | shipped | delivered | cancelled
  paymentStatus String   @default("unpaid") // unpaid | partial | paid | refunded
  paymentMethod String?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  items2       OrderItem[]
  invoices     Invoice[]

  @@index([businessId])
}

model OrderItem {
  id          String   @id @default(cuid())
  orderId     String
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId   String?
  product     Product? @relation(fields: [productId], references: [id])
  name        String
  qty         Int
  price       Int
  total       Int

  @@index([orderId])
}

model Invoice {
  id            String   @id @default(cuid())
  businessId    String
  business      Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  orderId       String?
  order         Order?   @relation(fields: [orderId], references: [id])
  userId        String?
  user          User?    @relation("InvoiceUser", fields: [userId], references: [id])
  invoiceNumber String
  customerName  String
  customerEmail String?
  items         String   // JSON array
  subtotal      Int
  tax           Int      @default(0)
  total         Int
  status        String   @default("draft") // draft | sent | paid | overdue | cancelled
  dueDate       DateTime?
  paidAt        DateTime?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([businessId])
}

model Customer {
  id          String   @id @default(cuid())
  businessId  String
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])
  name        String
  email       String?
  phone       String?
  company     String?
  address     String?
  notes       String?
  tags        String   @default("[]") // JSON array
  totalOrders Int      @default(0)
  totalSpent  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([businessId])
}

model Expense {
  id          String   @id @default(cuid())
  businessId  String
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])
  category    String
  amount      Int
  description String
  date        DateTime
  receipt     String?
  createdAt   DateTime @default(now())

  @@index([businessId])
}

model Staff {
  id          String   @id @default(cuid())
  businessId  String
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])
  name        String
  email       String
  role        String   @default("staff") // manager | staff | accountant
  permissions String   @default("[]") // JSON array
  active      Boolean  @default(true)
  invitedAt   DateTime @default(now())
  joinedAt    DateTime?
  createdAt   DateTime @default(now())

  @@index([businessId])
}

model Subscription {
  id            String   @id @default(cuid())
  businessId   String
  business     Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  plan         String   @default("free") // free | premium | enterprise
  status       String   @default("active") // active | cancelled | expired | past_due
  amount       Int      @default(0)
  billingCycle String   @default("monthly") // monthly | yearly
  startDate    DateTime @default(now())
  endDate      DateTime?
  paymentMethod String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([businessId])
}

model AdminAction {
  id          String   @id @default(cuid())
  adminId     String
  admin       User     @relation(fields: [adminId], references: [id])
  action      String   // business_approve | business_verify | business_suspend | user_role_change | review_remove etc.
  targetType  String   // business | user | review | enquiry | message
  targetId    String
  metadata    String   @default("{}") // JSON
  createdAt   DateTime @default(now())

  @@index([adminId])
  @@index([targetType, targetId])
}
